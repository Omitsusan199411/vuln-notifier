# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
pnpm/
.turbo/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# vitest coverage
coverage/

# bash履歴（workspace コンテナの /root が ./:/root でマウントされているため、コンテナ内の履歴がホストに漏れる。）
# アプリの設計上、./:/root を簡単に消すことはできない
.bash_history

packages/**/.pnpm-store/

# cursor mcp設定
.cursor

# ローカルキャッシュ
.cache
