{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"check": {
			"inputs": [
				"src/**/*.{ts,tsx,js,jsx,mjs,json}",
				"biome.jsonc",
				"package.json"
			]
		},
		"check:fix": {
			"cache": false
		}
	}
}
