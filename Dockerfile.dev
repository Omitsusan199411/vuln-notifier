FROM node:24-slim AS base

# pnpm run を介さずワークスペースルートのバイナリを直接実行できるようにする
ENV PATH=/root/node_modules/.bin/:$PATH

ENV PNPM_HOME=/root/pnpm

# corepack: package.json の packageManager に従って pnpm を呼び出せるようにする
RUN corepack enable

WORKDIR /root


FROM base AS workspace
# store を ./:/root bind mount 内に置き、再起動後も永続化する
CMD ["sh", "-c", "pnpm install && sleep infinity"]


FROM base AS api
WORKDIR /root/packages/api
EXPOSE 3001
CMD ["pnpm", "dev"]


FROM base AS web
WORKDIR /root/packages/web
EXPOSE 3000
CMD ["pnpm", "dev"]
